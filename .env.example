# ──────────────────────────────────────────────────────────────────────────────
# ReadScore environment configuration
# Copy this file to .env and fill in values for local development.
# In Railway, set these variables directly in the service's environment settings.
# ──────────────────────────────────────────────────────────────────────────────

# Port the Node API listens on locally.
# Railway ignores this and injects PORT automatically.
NODE_PORT=3000

# Internal URL the Node API uses to reach the Python service.
# In docker-compose this points to the compose service name.
# In Railway, set this to the private network URL of the python-service
# (e.g. http://python-service.railway.internal:8000).
PYTHON_SERVICE_URL=http://python-service:8000

# Port the Python analysis service listens on locally.
# Railway ignores this and injects PORT automatically.
PYTHON_PORT=8000

# Whisper model size used for audio transcription.
# Smaller models are faster; larger models are more accurate.
# Options: tiny, base, small, medium, large, large-v2, large-v3
WHISPER_MODEL=base

# Log level for the Node API.
# Options: trace, debug, info, warn, error, fatal, silent
LOG_LEVEL=info
